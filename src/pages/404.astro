---
import Base from "../layouts/Base.astro";
---

<Base
  title="Seite nicht gefunden — Marek Sommer"
  description="Diese Seite existiert nicht."
>
  <header class="pt-2 md:pt-8">
    <p class="font-mono text-label text-muted uppercase">
      <span class="text-signal" aria-hidden="true">404</span>
      Seite nicht gefunden
    </p>
    <h1
      class="mt-3 text-[2.125rem]/[1.15] font-semibold tracking-tight md:text-display"
    >
      Hier ist nichts.
    </h1>
    <p class="mt-6 max-w-prose">
      Die Adresse existiert nicht — vertippt oder veraltet.
    </p>
    <p class="mt-6 font-mono text-label uppercase">
      <a href="/">← Zur Startseite</a>
    </p>
  </header>

  <footer class="mt-20 border-t border-line pt-6 md:mt-28">
    <p class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-label text-muted">
      © 2026 Marek Sommer
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </p>
  </footer>
</Base>
