---
import Base from "../layouts/Base.astro";
---

<Base title="Impressum — Marek Sommer" description="Impressum von mareksommer.de">
  <header>
    <p class="font-mono text-label uppercase">
      <a href="/">← mareksommer.de</a>
    </p>
    <h1 class="mt-6 text-[1.75rem]/[1.2] font-semibold tracking-tight">
      Impressum
    </h1>
  </header>

  <section class="mt-10 space-y-6">
    <div>
      <h2 class="font-mono text-label text-muted uppercase">
        Angaben gemäß § 5 DDG
      </h2>
      <p class="mt-3">
        Marek Sommer<br />
        Sperberweg 6<br />
        66606 Bliesen
      </p>
    </div>
    <div>
      <h2 class="font-mono text-label text-muted uppercase">Kontakt</h2>
      <p class="mt-3">
        E-Mail:
        <a href="mailto:marek@mareksommer.de" class="num"
          >marek@mareksommer.de</a
        >
      </p>
    </div>
    <div>
      <h2 class="font-mono text-label text-muted uppercase">
        Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV
      </h2>
      <p class="mt-3">Marek Sommer, Anschrift wie oben</p>
    </div>
  </section>

  <footer class="mt-20 border-t border-line pt-6">
    <p class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-label text-muted">
      © 2026 Marek Sommer
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </p>
  </footer>
</Base>
